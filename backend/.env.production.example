NODE_ENV=production
PORT=8080

# Firebase — uses Application Default Credentials on Cloud Run (no key file needed)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_STORAGE_BUCKET=your-firebase-project-id.appspot.com

# OpenAI (optional — set MOCK_MODE=true to skip)
OPENAI_API_KEY=sk-...

# Storage
MAX_VIDEO_SIZE_MB=50

# Your Firebase Hosting URL (set after firebase deploy)
FRONTEND_URL=https://your-project-id.web.app

# Enable mock mode to bypass OpenAI API (for demo/presentation)
MOCK_MODE=true
